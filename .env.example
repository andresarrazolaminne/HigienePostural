# --- Base de datos ---
# SQLite (solo desarrollo local):
# DATABASE_URL=sqlite:///./ergonomia.db
#
# MySQL (producción). Codifica caracteres especiales de la contraseña en la URL:
#   python -c "from urllib.parse import quote_plus; print(quote_plus('TU_PASSWORD'))"
# DATABASE_URL=mysql+pymysql://USER:PASSWORD_ENCODED@HOST:3306/NOMBRE_BD

DATABASE_URL=sqlite:///./ergonomia.db

# Secreto para firmar JWT (NO es la clave de OpenAI). Genera uno aleatorio largo.

SECRET_KEY=change-me-to-a-long-random-string

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=60

# Clave de OpenAI (sk-proj-...), solo para analisis de fotos

OPENAI_API_KEY=

UPLOAD_DIR=uploads

ENVIRONMENT=development

STORAGE_BACKEND=local



# Orígenes CORS (solo necesario si el front llama a otro dominio/puerto)

# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173



# --- Docker local: .\docker-local.bat ---

# RUN_SEED=1

# WEB_PORT=9080



# --- Lightsail + S3 (obligatorio para deploy-lightsail.bat) ---
# Copia este bloque a .env y rellena los valores (sin comillas).

# CORS_ORIGINS=https://husky.tod.com.co,https://oya-app.xxxxx.us-east-1.cs.amazonlightsail.com
# STORAGE_BACKEND=s3
# S3_BUCKET=fow-tod-data
# S3_PREFIX=OYA-APP
# S3_PUBLIC_BASE_URL=https://fow-tod-data.s3.us-east-1.amazonaws.com
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alternativa: omitir las dos lineas AWS si ya usas "aws configure" en esta PC.



# PostgreSQL (alternativa)

# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/ergonomia



# Front (build Docker): VITE_API_URL vacío = mismo origen vía nginx

# VITE_API_URL=


